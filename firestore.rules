rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public leaderboard: anyone signed in may READ the rankings, but each entry
    // is writable only by its owner. Writes must keep the doc PII-free (uid +
    // first name + xp + level only) and the uid must match the doc id.
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly(['uid', 'displayName', 'companionXp', 'level', 'updatedAt']);
    }
  }
}
