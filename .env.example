VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
# Turn on the Phase 2 AI Challenge Mode (requires the Cloudflare Worker deployed).
VITE_AI_ENABLED=false
# URL of the deployed Cloudflare Worker that proxies OpenAI. Deploy it from worker/:
#   cd worker && npx wrangler secret put OPENAI_API_KEY && npx wrangler deploy
# then paste the printed *.workers.dev URL here. The OpenAI key stays in the
# Worker as a secret and is never shipped to the browser. The same base URL also
# serves TTS (/tts) and the AI custom-Pip image generator (/pip-image).
VITE_AI_PROXY_URL=
# Turn on the premium "Design your own Pip with AI" shop feature. Leave false until
# you've (1) enabled R2 in the Cloudflare dashboard, (2) created the bucket
# (cd worker && npx wrangler r2 bucket create count-me-in-pips), and (3) deployed
# the Worker (npx wrangler deploy). Until then the shop shows it as "coming soon".
VITE_AI_PIP_ENABLED=false
